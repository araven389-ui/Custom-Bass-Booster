{
  "manifest_version": 3,
  "name": "NEON BASS: Gamer Edition",
  "version": "1.1",
  "permissions": [
    "tabCapture",
    "offscreen",
    "activeTab",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "ico.png"
  },
  "icons": {
    "128": "ico.png"
  }
}